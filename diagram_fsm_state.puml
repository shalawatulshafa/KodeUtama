@startuml
title State Machine — 3tombolSync (Integrasi Penuh)

[*] --> WAKE_UP

state WAKE_UP {
  [*] --> Splash
  Splash : "WAKE UP! System Ready"
  Splash --> CekMode : setelah 1 detik
  CekMode : Baca boot_mode dari NVS
  CekMode --> AUDIO_MODE : boot_mode = AUDIO
  CekMode --> SYNC_MODE : boot_mode = SYNC
  CekMode --> DEEP_SLEEP : boot_mode = DEEP_SLEEP
}

state DEEP_SLEEP {
  [*] --> Sleep
  Sleep : MOSFET OFF, ESP deep sleep
  Sleep --> [*] : EXT0 wake (tekan OK)
}

state SAFE_MODE : boot_attempt > 3\nTampil error, tunggu cabut batrai

CekMode --> SAFE_MODE : crash 3x beruntun

' ═══ AUDIO MODE ═══
state AUDIO_MODE {
  [*] --> MAIN_MENU

  MAIN_MENU : 1. SCAN DEVICE\n2. SYNC\n3. EXIT

  MAIN_MENU --> SCANNING : OK → Scan
  MAIN_MENU --> SYNC_MODE : OK → SYNC\n(requestBootMode)
  MAIN_MENU --> IDLE : OK → EXIT\n(hanya jika terkoneksi)

  SCANNING : Scan A2DP earphone\n(20 detik)
  SCANNING --> SELECTING : scan selesai

  SELECTING : Pilih device dari list
  SELECTING --> PAIRING : OK → pair
  SELECTING --> SCANNING : OK → rescan

  PAIRING : Hubungkan ke earphone\nsimpan MAC ke NVS
  PAIRING --> MENU_PATTERN : CONNECTED

  MENU_PATTERN : Pilih Pola Napas\n■ 3:2 (RELAX)\n■ 2:1 (POWER)
  MENU_PATTERN --> IDLE : OK → Mulai

  ' ── State Gabungan: RUNNING ──
  state IDLE {
    [*] --> ANALYZING

    ANALYZING : Amati irama langkah\nhitung SPM, T_avg, stable_count
    ANALYZING --> GUIDING : stable_count > 5\n→ RECORDING MULAI

    state GUIDING {
      [*] --> Active
      Active : Audio cue HIRUP/BUANG\nwriteLogEntry tiap langkah
      Active --> Paused : >3 langkah meleset
      Paused : Audio HENING\nOLED: STATUS ANALYZING
      Paused --> Active : ritme stabil lagi\n→ RESUME
    }

    GUIDING --> ANALYZING : pause >3 langkah\ntanpa recording aktif
  }

  IDLE --> MAIN_MENU : tombol OK\n(long press)

  IDLE --> DEEP_SLEEP : tombol OK\n(>2 detik)
}

' ═══ SYNC MODE ═══
state SYNC_MODE {
  [*] --> Waiting_HP
  Waiting_HP : BLE Advertising\n"Cheaststrap"
  Waiting_HP --> Connected : HP connect

  Connected : Tunggu perintah\nKirim "SYNC" dari Flutter
  Connected --> Transferring : terima "SYNC"

  Transferring : Baca /run.dat\nKonversi biner→CSV\nKirim via BLE Notify
  Transferring --> Wait_ACK : EOF terkirim

  Wait_ACK : Tunggu ACK dari HP\n(timeout 30 detik)
  Wait_ACK --> Success : terima "OK"
  Wait_ACK --> AUDIO_MODE : timeout / gagal

  Success : HAPUS /run.dat\nTunggu user tekan OK
  Success --> AUDIO_MODE : user konfirmasi
}

AUDIO_MODE --> DEEP_SLEEP : battery critical

@enduml