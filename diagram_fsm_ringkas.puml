@startuml
title State Machine 3tombolSync

left to right direction
skinparam stateFontSize 12

[*] --> BOOT
BOOT --> SAFE_MODE : crash 3x
BOOT --> SLEEP : boot = DEEP_SLEEP
BOOT --> SYNC : boot = SYNC
BOOT --> MENU : boot = AUDIO

state MENU #LightYellow : MAIN MENU\n1.Scan 2.Sync 3.Exit
state SCAN #LightBlue : SCANNING\n(20 detik)
state PAIR : Pair & Connect
state POLA : Pilih Pola\n3:2 / 2:1

MENU --> SCAN : OK→Scan
MENU --> SYNC : OK→Sync
MENU --> IDLE : OK→Exit

SCAN --> PAIR : pilih device
PAIR --> POLA : CONNECTED
POLA --> IDLE : OK→Mulai

' ── HEART OF SYSTEM ──
state IDLE #LightGreen {
    ANALYZING --> GUIDING : stable>5\n→ REC START
    GUIDING --> ANALYZING : >3 meleset\n→ REC PAUSE
}

state ANALYZING : Amati irama\nhitung SPM
state GUIDING : Audio CUE\nLOG per langkah

IDLE --> MENU : long OK
IDLE --> SLEEP : OK>2detik

' ── SYNC ──
state SYNC #Thistle {
    [*] --> Wait
    Wait : BLE advertising
    Wait --> TX : HP→"SYNC"
    TX : Baca /run.dat\nkirim CSV
    TX --> ACK : EOF
    ACK : tunggu "OK"
    ACK --> Done : terima ACK
    Done : hapus file
    Done --> [*]
    ACK --> [*] : timeout
}

SYNC --> MENU : selesai/gagal

' ── SLEEP ──
SLEEP : MOSFET OFF\nesp_deep_sleep
SLEEP --> BOOT : tekan OK\n(EXT0 wake)

@enduml